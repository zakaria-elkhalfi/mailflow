# Email Automation - Environment Variables
# Copy this file to .env and fill in your credentials

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# From display name
FROM_NAME=My App

# Server port
PORT=3000

# Delay between emails in milliseconds (2000 = 2 seconds)
EMAIL_DELAY_MIN=2000
EMAIL_DELAY_MAX=5000

# Delay between WhatsApp messages (5-15 seconds recommended to avoid ban)
WA_DELAY_MIN=5000
WA_DELAY_MAX=15000
